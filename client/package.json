    "yup": "^0.32.11"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:emulators": "env-cmd -e common,dev,emulators react-scripts start",
    "build": "react-scripts --max_old_space_size=4096 build",
    "build:dev:emulators": "env-cmd -e common,dev,emulators npm run build",
    "build:prod:emulators": "env-cmd -e common,prod,emulators npm run build",
    "build:dev": "env-cmd -e common,dev npm run build",
    "build:prod": "env-cmd -e common,prod npm run build",
    "deploy": "npm run build:prod && firebase deploy --only hosting",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/autosuggest-highlight": "^3.2.0"
  }
