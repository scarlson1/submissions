{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://127.0.0.1:5001",
  "scripts": {
    "start": "react-scripts start",
    "start:emulators": "env-cmd -f ./.env.local env-cmd -e common,dev,emulators --no-override react-scripts start",
    "build": "react-scripts --max_old_space_size=4096 build",
    "build:dev:emulators": "env-cmd -e common,dev,emulators npm run build",
    "build:prod:emulators": "env-cmd -e common,prod,emulators npm run build",
    "build:dev": "env-cmd -e common,dev npm run build",
    "build:channel:dev": "env-cmd -e common,dev,staging npm run build",
    "build:channel:prod": "env-cmd -e common,prod,staging npm run build",
    "build:prod": "env-cmd -e common,prod npm run build",
    "deploy:dev": "npm run use:dev && npm run build:dev && firebase deploy --only hosting",
    "deploy:prod": "npm run use:prod && npm run build:prod && firebase deploy --only hosting",
    "deploy:channel:dev": "npm run use:dev && firebase hosting:channel:deploy staging --expires 7d",
    "deploy:channel:prod": "npm run use:prod && firebase hosting:channel:deploy staging --expires 7d",
    "create:channel:dev": "npm run use:dev && firebase hosting:channel:create staging",
    "create:channel:prod": "npm run use:prod && firebase hosting:channel:create staging",
    "use:dev": "firebase use dev",
    "use:prod": "firebase use prod",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint --ext .ts,.tsx ./src"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.9.2",
