{
  "name": "data-pipeline",
  "type": "module",
  "scripts": {
    "lint": "eslint --ext .js,.ts",
    "build": "rm -rf ./dist/ && tsc",
    "dev": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "shell:inspect": "npm run build:watch && firebase functions:shell --inspect-functions",
    "start": "npm run shell",
    "deploy:dev": "npm run use:dev && npx firebase deploy --only functions",
    "deploy:prod": "npm run use:prod && npx firebase deploy --only functions",
    "use:dev": "firebase use dev",
    "use:prod": "firebase use prod",
    "test": "jest",
    "logs": "firebase functions:log",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "src",
    "dist"
  ],
  "jest": {
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./src/test/setup.ts"
    ]
  },
  "engines": {
    "node": "22"
  },
  "main": "dist/index.js",
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/functions-framework": "^5.0.2",
    "@google-cloud/pubsub": "^4.0.6",
    "@idemand/common": "workspace:*",
    "@sentry/node": "^7.51.2",
    "@sentry/tracing": "^7.51.2",
    "@sentry/utils": "^8.55.0",
    "firebase-admin": "13.7.0",
    "firebase-functions": "^7.7.2",
    "firebase-functions-test": "^3.1.0",
    "tiny-invariant": "^1.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@sentry/types": "^10.44.0",
    "@types/node": "~22.19.15",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-turbo": "^2.9.5",
    "eslint-plugin-import": "^2.25.4",
    "jest": "^29.6.3",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "private": true,
  "version": "1.0.0"
}
