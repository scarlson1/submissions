{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "env-cmd -f ./.env.local env-cmd -e common,emulators,dev --no-override pnpm tsx watch ./src/index.ts",
    "dev:old": "pnpm use:dev && env-cmd -f ./.env.local env-cmd -e common,emulators,dev --no-override nodemon -I --exec node --experimental-specifier-resolution=node --loader ts-node/esm ./src/index.ts",
    "setSAPath:dev": "export GOOGLE_APPLICATION_CREDENTIALS=\"/Users/spencercarlson/dev/service_accounts/idemand-submissions-dev-firebase-admin.json\"",
    "setSAPath:prod": "export GOOGLE_APPLICATION_CREDENTIALS=\"/Users/spencercarlson/dev/service_accounts/idemand-submissions-firebase-admin.json\"",
    "docker:dev": "gcloud beta code dev --application-default-credential --local-port=8080",
    "compose:dev": "docker compose -f docker-compose-dev.yml up --build",
    "build": "rimraf ./dist && tsc",
    "build:dev": "env-cmd -e common,dev pnpm build",
    "build:prod": "env-cmd -e common,prod pnpm build",
    "typecheck": "tsc --noEmit",
    "use:dev": "gcloud config set project idemand-submissions-dev",
    "use:prod": "gcloud config set project idemand-submissions",
    "deploy:dev": "gcloud config set project idemand-submissions-dev && gcloud run deploy idemand-submissions-api --source ../.. --env-vars-file=\"./env-dev.yaml\"",
    "deploy:prod": "gcloud config set project idemand-submissions && gcloud run deploy idemand-submissions-api --source ../..",
    "deploy:dev:old": "pnpm use:dev && gcloud run deploy idemand-submissions-api --env-vars-file=\"./env-dev.yaml\"",
    "deploy:prod:old": "pnpm use:prod && gcloud run deploy",
    "start": "node dist/index.js",
    "start:old": "node --experimental-specifier-resolution=node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/secret-manager": "^4.2.0",
    "@idemand/common": "workspace:*",
    "axios": "^1.4.0",
    "cors": "^2.8.6",
    "env-cmd": "^10.1.0",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.7.0",
    "jsonwebtoken": "^9.0.3",
    "lodash-es": "^4.17.21",
    "morgan": "^1.10.0",
    "nanoid": "^5.0.3",
    "tiny-invariant": "^1.3.1",
    "winston": "^3.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash-es": "^4.17.9",
    "@types/morgan": "^1.9.4",
    "@types/node": "^22.19.15",
    "nodemon": "^2.0.20",
    "rimraf": "^4.1.2",
    "tsconfig-paths": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2"
  }
}
