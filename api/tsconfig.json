{
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  },
  "compilerOptions": {
    "lib": ["es2022"],
    // "module": "es2022",
    "module": "NodeNext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    // "target": "es2022",
    "target": "ESNext",
    // "moduleResolution": "node",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "typeRoots": ["./node_modules/@types", "src/common"]
    // "baseUrl": "./src"
    // "paths": { // not working with ts-node/esm
    //   "@/*": ["*"]
    // }
  },
  "compileOnSave": true,
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "lib", "node_modules"]
}
