{
  "name": "submissions",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "client:dev": "pnpm --filter client dev",
    "client:live": "pnpm --filter client start",
    "functions:build": "pnpm --filter functions dev",
    "emulators:dev": "firebase emulators:start --only functions,auth,firestore,storage,pubsub,eventarc --import ./emulator-data",
    "emulators:save": "firebase emulators:export ./emulator-data",
    "use:dev": "firebase use dev",
    "use:prod": "firebase use prod",
    "setSAPath:dev": "export GOOGLE_APPLICATION_CREDENTIALS=\"/Users/spencercarlson/dev/service_accounts/idemand-submissions-dev-firebase-admin.json\"",
    "setSAPath:prod": "export GOOGLE_APPLICATION_CREDENTIALS=\"/Users/spencercarlson/dev/service_accounts/idemand-submissions-firebase-admin.json\"",
    "deploy:rules:firestore": "firebase deploy --only firestore:rules",
    "deploy:rules:storage": "firebase deploy --only storage",
    "deploy:api:dev": "gcloud config set project idemand-submissions-dev && gcloud run deploy idemand-submissions-api --source . --env-vars-file=\"./api/env-dev.yaml\"",
    "deploy:api:prod": "gcloud config set project idemand-submissions && gcloud run deploy idemand-submissions-api --source .",
    "list:java": "ps -ax | grep java",
    "ngrok": "ngrok http --url=wondrous-opossum-sensible.ngrok-free.app 5001",
    "tailscale": "tailscale funnel 5001",
    "typesense:dev": "docker run -p 8108:8108 -v\"$(pwd)\"/typesense-data:/data typesense/typesense:29.0 --data-dir /data --api-key=xyz --enable-cors",
    "stripe:forward": "stripe listen --forward-to localhost:5001/idemand-submissions-dev/us-central1/stripe/webhook"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22",
      "firebase-admin": "13.7.0",
      "@google-cloud/firestore": "8.3.0",
      "firebase-functions": "^7.2.2"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarlson1/submissions.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/scarlson1/submissions/issues"
  },
  "homepage": "https://github.com/scarlson1/submissions#readme",
  "devDependencies": {
    "firebase-tools-with-isolate": "^14.16.0"
  }
}
