{
  "name": "submissions",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "client:dev": "npm run start:emulators --prefix ./client",
    "client:live": "npm run start --prefix ./client",
    "functions:build": "npm run build:watch --prefix ./functions",
    "emulators:dev": "firebase emulators:start --only functions,auth,firestore,storage,pubsub --import ./emulator-data",
    "dev": "npm run setSAPath && concurrently \"npm run client:dev\" \"npm run functions:build\" \"npm run emulators:dev\"",
    "setSAPath": "export GOOGLE_APPLICATION_CREDENTIALS=\"/Users/spencercarlson/code/idemand-submissions-firebase-admin.json\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scarlson1/submissions.git"
