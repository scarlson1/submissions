{
  "compilerOptions": {
    "module": "ES2022",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "dist",
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "skipLibCheck": true, // Add this to skip type checking of declaration files
    "checkJs": false,
    "types": ["node"] // Only include the types you need
  },
  "compileOnSave": true,
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": ["src/**/*.js", "src/**/*.jsx", "node_modules"]
}
